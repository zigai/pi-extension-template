_:
    @just help

# List available commands
help:
    @just --list

# Format code
fmt:
    npm run format

# Check code for lint issues
lint:
    npm run lint

# Run tests
test:
    npm test

# Run all non-mutating quality checks
check:
    npm run check

# Run tests with coverage
coverage:
    npm run coverage

# Apply automatic lint fixes and format code
fix:
    npm run lint:fix
    npm run format

alias cov := coverage
